---
import { platformSections } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"><img src="/brand/agrowth-mark-96.webp" alt="" width="96" height="96" loading="lazy" decoding="async" /></span>
          <span class="brand-name">AGrowth <small>Ad Account Desk</small></span>
        </a>
        <p class="footer-intro">Policy-led guidance for account restrictions, suspensions, reviews, appeals, and controls that reduce repeat issues.</p>
      </div>
      <div>
        <p class="footer-title">Platforms</p>
        <div class="footer-links">
          {platformSections.map((item) => <a href={`/${item.slug}/`}>{item.eyebrow}</a>)}
          <a href="/appeals-compliance/">Appeals & Compliance</a>
        </div>
      </div>
      <div>
        <p class="footer-title">AGrowth</p>
        <div class="footer-links">
          <a href="/blog/">All guides</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/search/">Search</a>
          <a href="/sitemap-index.xml">Sitemap</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} AGrowth. All rights reserved.</span>
      <span>Independent guidance. Not affiliated with Meta, Google, or TikTok.</span>
    </div>
  </div>
</footer>
