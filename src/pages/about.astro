---
import BaseLayout from '../layouts/BaseLayout.astro';
import { companyMetrics, companyProfileUrl, editorialLead } from '../data/authority';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'AGrowth',
      url: 'https://agrowth.io/',
      employee: {
        '@type': 'Person',
        name: editorialLead.name,
        jobTitle: editorialLead.role,
        url: editorialLead.profileUrl
      }
    },
    {
      '@type': 'Person',
      name: editorialLead.name,
      jobTitle: editorialLead.role,
      worksFor: { '@type': 'Organization', name: 'AGrowth', url: 'https://agrowth.io/' },
      url: editorialLead.profileUrl
    }
  ]
};
---

<BaseLayout title="About AGrowth" description="Learn about AGrowth, the team and editorial experience behind its advertising account restriction, compliance and operations guides." structuredData={structuredData}>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p class="eyebrow">About AGrowth</p>
      <h1>Practical knowledge for complex ad account operations.</h1>
      <p class="lede">Ad Account Desk by AGrowth organizes common advertising account issues into clear platform, compliance, appeal, and operational focus areas.</p>
    </div>
  </section>
  <section class="section section--white">
    <div class="container info-layout">
      <div class="info-aside">
        <p class="eyebrow">Our focus</p>
        <p>Meta Ads · Google Ads · TikTok Ads · Appeals · Compliance · Agency accounts</p>
      </div>
      <div class="prose">
        <h2>Built to make the next step clearer.</h2>
        <p>Advertising account restrictions can involve platform policy, billing, identity, business verification, security, or connected assets. The Desk brings those areas together so operators can diagnose issues more methodically.</p>
        <p>Our coverage spans Facebook and Meta ad account restrictions, Google Ads suspensions, TikTok Ads and Business Center enforcement, appeal preparation, agency account options, and cross-platform account operations.</p>
        <h3>Independent guidance</h3>
        <p>AGrowth is not Meta, Google, or TikTok, and does not control their enforcement decisions. Platform names and trademarks belong to their respective owners.</p>
        <h3>Responsible operations</h3>
        <p>Our editorial approach favors accurate business information, documented access, secure payment operations, transparent provider relationships, and compliance with applicable platform policies.</p>
      </div>
    </div>
  </section>
  <section class="section about-authority">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">Company experience</p><h2>Published AGrowth credentials.</h2></div>
        <p>These figures are reported on AGrowth’s primary company website and linked for direct verification.</p>
      </div>
      <div class="trust-metrics trust-metrics--about">
        {companyMetrics.map((metric) => (
          <div class="trust-metric"><strong>{metric.value}</strong><span>{metric.label}</span></div>
        ))}
      </div>
      <a class="trust-source" href={companyProfileUrl} rel="external">View the AGrowth company profile <span aria-hidden="true">↗</span></a>
    </div>
  </section>
  <section class="section section--white">
    <div class="container editorial-profile">
      <div>
        <p class="eyebrow">Editorial leadership</p>
        <h2>{editorialLead.name}</h2>
        <p class="editorial-role">{editorialLead.role}</p>
      </div>
      <div class="prose">
        <p>{editorialLead.description}</p>
        <p>AGrowth’s primary blog identifies Alan Tran as the author of its platform guides and current advertising-industry coverage. Ad Account Desk articles are published under AGrowth’s organizational authorship and reviewed by the AGrowth editorial team.</p>
        <a class="button button--dark" href={editorialLead.profileUrl} rel="external">View published author profile <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
