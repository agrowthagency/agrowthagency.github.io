---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { articleUrl, siloInfo } from '../../data/silos';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => {
    const [silo, articleSlug] = article.id.split('/');
    return {
      params: { silo, article: articleSlug },
      props: {
        article,
        related: articles
          .filter((item) => item.data.silo === article.data.silo && item.id !== article.id)
          .slice(0, 3)
      }
    };
  });
}

interface Props {
  article: CollectionEntry<'articles'>;
  related: CollectionEntry<'articles'>[];
}
const { article, related } = Astro.props;
const { data } = article;
const silo = siloInfo[data.silo];
const url = articleUrl(article.id);
const published = data.publishedDate.toISOString().slice(0, 10);
const modified = data.updatedDate.toISOString().slice(0, 10);
const displayDate = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' }).format(data.publishedDate);
const { Content, headings } = await render(article);
const tableOfContents = headings.filter((heading) => heading.depth === 2);

const faq = [
  {
    question: `What should I check first for ${data.topic.toLowerCase()}?`,
    answer: 'Start with the exact in-product notice, the affected asset, the decision date, and recent changes. Preserve this evidence before changing campaigns, billing, users, or connected assets.'
  },
  {
    question: `Can a provider guarantee a successful outcome?`,
    answer: 'No. Enforcement and review decisions belong to the advertising platform. A responsible provider can help organize evidence and operations, but cannot guarantee reinstatement, approval, spend, or immunity from future policy action.'
  },
  {
    question: `Should I create another account while this issue is unresolved?`,
    answer: 'Do not create or source accounts to bypass enforcement. Preserve the original record, understand the platform notice, correct confirmed issues, and use the official review or support channel.'
  }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: data.title,
      description: data.description,
      datePublished: published,
      dateModified: modified,
      mainEntityOfPage: new URL(url, Astro.site).href,
      author: { '@type': 'Organization', name: 'AGrowth', url: new URL('/about/', Astro.site).href },
      publisher: { '@type': 'Organization', name: 'AGrowth' },
      articleSection: silo.name,
      keywords: [data.topic, silo.name, 'ad account operations']
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: silo.name, item: new URL(`/${data.silo}/`, Astro.site).href },
        { '@type': 'ListItem', position: 3, name: data.title, item: new URL(url, Astro.site).href }
      ]
    },
    {
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer }
      }))
    }
  ]
};
---

<BaseLayout
  title={data.title}
  seoTitle={`${data.topic} Guide | AGrowth`}
  description={data.description}
  structuredData={structuredData}
  ogType="article"
  publishedTime={published}
>
  <article class="article-page">
    <header class="article-hero">
      <div class="container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Home</a><span aria-hidden="true">/</span>
          <a href={`/${data.silo}/`}>{silo.name}</a><span aria-hidden="true">/</span>
          <span aria-current="page">{data.topic}</span>
        </nav>
        <div class="article-hero-grid">
          <div>
            <p class="eyebrow">{silo.name} guide</p>
            <h1>{data.title}</h1>
            <p class="article-deck">{data.description}</p>
          </div>
          <div class="article-meta-card">
            <span>Published</span><strong>{displayDate}</strong>
            <span>Reviewed by</span><strong>AGrowth Editorial</strong>
            <span>Reading time</span><strong>6 minutes</strong>
          </div>
        </div>
      </div>
    </header>

    <div class="container article-layout">
      <aside class="article-sidebar">
        <p>On this page</p>
        <nav aria-label="Table of contents">
          <a href="#quick-answer">Quick answer</a>
          {tableOfContents.map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
          <a href="#faq">FAQ</a>
          <a href="#sources">Official sources</a>
        </nav>
      </aside>

      <div class="article-content">
        <section class="quick-answer" id="quick-answer">
          <span>Quick answer</span>
          <p>{data.overview}</p>
        </section>

        <div class="markdown-content">
          <Content />
        </div>

        <section id="faq">
          <p class="section-kicker">Frequently asked questions</p>
          <h2>{data.topic}: FAQ</h2>
          <div class="faq-list">
            {faq.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section id="sources" class="source-section">
          <p class="section-kicker">Primary references</p>
          <h2>Official platform resources</h2>
          <p>Platform interfaces and policies change. Confirm current requirements in the official resources before taking action.</p>
          <div class="source-links">
            {silo.sources.map((source) => <a href={source.href} rel="external">{source.label}<span aria-hidden="true">↗</span></a>)}
          </div>
        </section>

        <aside class="editorial-note">
          <strong>Editorial note</strong>
          <p>This guide provides general operational information, not legal advice or a guarantee of account approval, reinstatement, or performance. Platform decisions remain with Meta, Google, TikTok, and other applicable providers.</p>
        </aside>
      </div>
    </div>
  </article>

  <section class="section section--ink related-section">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">Continue this silo</p><h2>Related {silo.name} guides.</h2></div>
        <a class="button button--light" href={`/${data.silo}/`}>View the complete silo</a>
      </div>
      <div class="related-grid">
        {related.map((item) => (
          <a href={articleUrl(item.id)}>
            <span>{item.data.topic}</span>
            <h3>{item.data.title}</h3>
            <p>{item.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
