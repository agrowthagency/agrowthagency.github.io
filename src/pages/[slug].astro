---
import BaseLayout from '../layouts/BaseLayout.astro';
import { allSections, type TopicSection } from '../data/site';
import { getCollection, type CollectionEntry } from 'astro:content';
import { articleUrl } from '../data/silos';
import { platformCaseStudies } from '../data/authority';
import { deskFaqs } from '../data/deskFaqs';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return allSections.map((section) => ({
    params: { slug: section.slug },
    props: {
      section,
      articles: articles.filter((article) => article.data.silo === section.slug)
    }
  }));
}

interface Props {
  section: TopicSection;
  articles: CollectionEntry<'articles'>[];
}
const { section, articles } = Astro.props;
const caseStudy = platformCaseStudies[section.slug];
const faq = deskFaqs[section.slug] ?? [];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: section.eyebrow, item: new URL(`/${section.slug}/`, Astro.site).href }
      ]
    },
    ...(faq.length ? [{
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer }
      }))
    }] : [])
  ]
};
---

<BaseLayout title={section.eyebrow} description={section.description} structuredData={structuredData}>
  <section class="page-hero">
    <div class="container page-hero-inner">
      <nav class="page-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span aria-hidden="true">/</span>
        <span aria-current="page">{section.eyebrow}</span>
      </nav>
      <p class="eyebrow">{section.eyebrow} desk</p>
      <h1>{section.title}</h1>
      <p class="lede">{section.description}</p>
      <div class="page-hero-note">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 11v5m0-8v.1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <p>{section.intro}</p>
      </div>
    </div>
  </section>

  {caseStudy && (
    <section class="section platform-proof-section">
      <div class="container platform-proof">
        <div class="platform-proof-copy">
          <p class="eyebrow">{caseStudy.eyebrow}</p>
          <h2>{caseStudy.client}</h2>
          <p>{caseStudy.summary}</p>
          <a href={caseStudy.sourceUrl} rel="external">{caseStudy.sourceLabel} <span aria-hidden="true">↗</span></a>
        </div>
        <div class="platform-proof-metrics" aria-label={`Reported results for ${caseStudy.client}`}>
          {caseStudy.metrics.map((metric) => (
            <div><strong>{metric.value}</strong><span>{metric.label}</span></div>
          ))}
        </div>
        <p class="proof-disclaimer">These are results reported for one published engagement or audit example, not a promise of future performance or account reinstatement.</p>
      </div>
    </section>
  )}

  <section class="section section--white">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Core topics</p>
          <h2>What this desk covers.</h2>
        </div>
        <p>Use these focus areas to organize your research and identify which part of the account lifecycle requires attention.</p>
      </div>
      <div class="topic-list">
        {articles.map((article) => (
          <a class="topic-list-item" href={articleUrl(article.id)}>
            <div>
              <h2>{article.data.topic}</h2>
              <p>{article.data.description}</p>
              <span class="topic-read">Read guide <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container info-layout">
      <div class="info-aside">
        <p class="eyebrow">Working principle</p>
        <p>Account enforcement decisions belong to each advertising platform. No independent provider can guarantee reinstatement or immunity from policy enforcement.</p>
      </div>
      <div class="prose">
        <h2>Use evidence, not assumptions.</h2>
        <p>Begin with the exact platform notice and the assets it names. Compare that notice against recent account changes, access events, billing activity, business verification, landing pages, and campaign history.</p>
        <h3>Keep the account record consistent</h3>
        <p>Business details, payment ownership, domain information, identity documents, and support explanations should describe the same legitimate operation. Inconsistency can make review more difficult.</p>
        <h3>Prioritize prevention</h3>
        <p>Document account ownership, use role-based access, protect administrator identities, review payment methods, and track material changes. These controls support both daily operations and future reviews.</p>
        <a class="button button--dark" href="/contact/">Discuss account operations</a>
      </div>
    </div>
  </section>

  {faq.length > 0 && (
    <section class="section section--white desk-faq-section">
      <div class="container desk-faq-layout">
        <div>
          <p class="eyebrow">Common questions</p>
          <h2>{section.shortLabel} FAQ.</h2>
          <p>Short answers for choosing the correct diagnosis and review path.</p>
        </div>
        <div class="faq-list">
          {faq.map((item) => (
            <details>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
