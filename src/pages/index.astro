---
import BaseLayout from '../layouts/BaseLayout.astro';
import { platformSections, guideSections } from '../data/site';
import { companyMetrics, companyProfileUrl } from '../data/authority';

const description = 'Practical guides on Meta, Google Ads and TikTok Ads account restrictions, suspensions, appeals, compliance and agency account operations.';
---

<BaseLayout title="Ad Account Desk by AGrowth" description={description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-main">
        <p class="eyebrow">Independent advertising operations desk</p>
        <h1>Ad account restricted? <span>Find the right next step.</span></h1>
        <p class="hero-lede">Choose Meta, Google Ads, or TikTok Ads to diagnose the issue, preserve the right evidence, and follow the relevant review path.</p>
        <div class="hero-actions">
          <a class="button button--gradient" href="#platforms">Choose your ad platform <span aria-hidden="true">→</span></a>
          <a class="hero-secondary-link" href="/contact/">Need help from AGrowth?</a>
        </div>
        <div class="hero-meta" aria-label="Website focus">
          <div><svg viewBox="0 0 24 24" fill="none"><path d="m5 12 4 4L19 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Policy-led guidance</div>
          <div><svg viewBox="0 0 24 24" fill="none"><path d="m5 12 4 4L19 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Multi-platform coverage</div>
          <div><svg viewBox="0 0 24 24" fill="none"><path d="m5 12 4 4L19 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Practical operations</div>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-orbit hero-orbit--one"></div>
        <div class="hero-orbit hero-orbit--two"></div>
        <div class="hero-logo-wrap"><img src="/brand/agrowth-mark.png" alt="" /></div>
        <div class="hero-float hero-float--top"><span>01</span><p>Policy first</p></div>
        <div class="hero-float hero-float--bottom"><span>Always on</span><p>Account clarity</p></div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-labelledby="trust-heading">
    <div class="container">
      <div class="trust-heading">
        <div><p class="eyebrow">AGrowth in numbers</p><h2 id="trust-heading">Experience behind the guidance.</h2></div>
        <p>Company-reported figures from AGrowth’s primary website. Results vary by advertiser, account history, market, and platform review.</p>
      </div>
      <div class="trust-metrics">
        {companyMetrics.map((metric) => (
          <div class="trust-metric"><strong>{metric.value}</strong><span>{metric.label}</span></div>
        ))}
      </div>
      <a class="trust-source" href={companyProfileUrl} rel="external">Verify these figures on agrowth.io <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section class="container signal-wrap" aria-label="Account response framework">
    <div class="signal-panel">
      <div class="signal-brand" aria-hidden="true"><img src="/brand/agrowth-mark.png" alt="" /></div>
      <p class="signal-label">The AGrowth response framework</p>
      <div class="signal-content">
        <div class="signal-heading"><div class="signal-number">03</div><p>Move from an account alert toward an evidence-based response.</p></div>
        <div class="signal-steps">
          <div class="signal-step"><span>01</span><strong>Diagnose the scope</strong><em>Observe</em></div>
          <div class="signal-step"><span>02</span><strong>Correct root causes</strong><em>Resolve</em></div>
          <div class="signal-step"><span>03</span><strong>Prepare the review</strong><em>Respond</em></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--white" id="platforms">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">Platform desks</p><h2>Choose your platform. Find your next move.</h2></div>
        <p>Each platform uses different enforcement surfaces, review paths, and account structures. Choose yours to find the right starting point.</p>
      </div>
      <div class="platform-grid">
        {platformSections.map((section, index) => (
          <a class="platform-card" data-accent={section.accent} href={`/${section.slug}/`}>
            <div class="card-top">
              <span class="card-index">0{index + 1}</span>
              <h3>{section.eyebrow}</h3>
              <p>{section.description}</p>
            </div>
            <div class="card-link"><span>{section.topics.length} focus areas</span><span aria-hidden="true">↗</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--gradient">
    <div class="container">
      <div class="section-heading">
        <div><p class="eyebrow">Beyond one platform</p><h2>Build durable account operations.</h2></div>
        <p>Restrictions rarely happen in isolation. Strong documentation, access control, billing hygiene, and provider due diligence matter everywhere.</p>
      </div>
      <div class="topic-strip">
        {guideSections.map((section) => (
          <article class="topic-card">
            <div class="topic-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 4.5 6v5.2c0 4.6 3.2 8.8 7.5 9.8 4.3-1 7.5-5.2 7.5-9.8V6L12 3Z" stroke="currentColor" stroke-width="1.7"/><path d="m9 12 2 2 4-5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>{section.eyebrow}</h3>
            <p>{section.description}</p>
            <a href={`/${section.slug}/`}>Explore {section.shortLabel} <span aria-hidden="true">→</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container process-grid">
      <div class="process-intro">
        <p class="eyebrow">A disciplined response</p>
        <h2>Before you appeal, build the full picture.</h2>
        <p>Fast reactions can create inconsistent records. A structured review helps you separate the visible alert from the underlying business, billing, policy, or security issue.</p>
        <a class="button button--gradient" href="/appeals-compliance/">Appeals & compliance</a>
      </div>
      <div class="process-list">
        <article class="process-item"><span class="process-number">01</span><div><h3>Map the restriction</h3><p>Identify whether enforcement affects an ad, advertiser account, manager, payment profile, business entity, or connected asset.</p></div></article>
        <article class="process-item"><span class="process-number">02</span><div><h3>Preserve the evidence</h3><p>Record notices, timestamps, account IDs, recent changes, billing events, access history, and previous support interactions.</p></div></article>
        <article class="process-item"><span class="process-number">03</span><div><h3>Correct the cause</h3><p>Resolve verifiable policy, security, business information, or payment issues before asking the platform to review again.</p></div></article>
        <article class="process-item"><span class="process-number">04</span><div><h3>Submit a consistent review</h3><p>Explain the issue, remediation, supporting evidence, and preventive controls clearly—without speculation or conflicting claims.</p></div></article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-inner">
      <div><p class="cta-kicker">Let’s build clarity</p><h2>Need a clearer path through an account issue?</h2><p>Connect with AGrowth about advertising account operations and agency account solutions.</p></div>
      <a class="button button--light" href="/contact/">Start a conversation <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>
