---
import BaseLayout from '../layouts/BaseLayout.astro';
import { platformSections, guideSections } from '../data/site';
import { companyMetrics, companyProfileUrl } from '../data/authority';
import '../styles/home.css';

const description = 'Practical guides on Meta, Google Ads and TikTok Ads account restrictions, suspensions, appeals, compliance and agency account operations.';
const platformCodes: Record<string, string> = { meta: 'M', google: 'G', tiktok: 'T' };
const platformSignals: Record<string, string[]> = {
  meta: ['Restrictions', 'Business assets', 'Account review'],
  google: ['Suspensions', 'Verification', 'Reinstatement'],
  tiktok: ['Account health', 'Business Center', 'Appeals']
};
---

<BaseLayout title="Ad Account Desk by AGrowth" description={description} bodyClass="home-page">
  <div class="scroll-progress" aria-hidden="true"></div>
  <section class="home-hero">
    <div class="hero-noise" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container home-hero__inner">
      <div class="hero-intro">
        <p class="home-kicker"><span></span> Independent advertising operations desk</p>
        <p class="hero-edition">AG / DESK <sup>01</sup></p>
      </div>

      <div class="hero-title-wrap">
        <h1>When ad accounts stop,<br /><em>your next move</em> shouldn’t.</h1>
        <div class="hero-title-mark" aria-hidden="true">
          <span>Diagnose</span><span>Resolve</span><span>Respond</span>
        </div>
      </div>

      <div class="hero-lower">
        <div class="hero-copy">
          <p>Clear, evidence-led guidance for account restrictions, suspensions, appeals and advertising operations across the platforms that move your business.</p>
          <div class="hero-actions">
            <a class="home-button home-button--primary" href="#platforms"><span>Find your platform</span><b aria-hidden="true">↗</b></a>
            <a class="home-button home-button--text" href="/contact/"><span>Talk to AGrowth</span><b aria-hidden="true">→</b></a>
          </div>
        </div>

        <div class="signal-console" aria-label="AGrowth response framework illustration">
          <div class="console-head">
            <span><i></i> Response system online</span>
            <span>AG—01</span>
          </div>
          <div class="console-body">
            <div class="console-radar" aria-hidden="true">
              <div class="radar-ring radar-ring--one"></div>
              <div class="radar-ring radar-ring--two"></div>
              <div class="radar-axis"></div>
              <div class="radar-logo"><img src="/brand/agrowth-mark-96.webp" alt="" width="96" height="96" fetchpriority="high" /></div>
              <span class="radar-ping radar-ping--one"></span>
              <span class="radar-ping radar-ping--two"></span>
            </div>
            <div class="console-readout">
              <span>Current protocol</span>
              <strong>Evidence<br />before action.</strong>
              <div class="readout-bars" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
            </div>
          </div>
          <div class="console-foot">
            <div><span>01</span><p>Diagnose</p></div>
            <div><span>02</span><p>Correct</p></div>
            <div><span>03</span><p>Review</p></div>
          </div>
        </div>
      </div>

      <div class="hero-metrics" aria-label="AGrowth company figures">
        {companyMetrics.map((metric) => (
          <div class="hero-metric"><strong>{metric.value}</strong><span>{metric.label}</span></div>
        ))}
        <a href={companyProfileUrl} rel="external">Company-reported figures <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <div class="signal-ticker" aria-hidden="true">
    <div class="signal-ticker__track">
      <span>Meta Ads</span><i></i><span>Google Ads</span><i></i><span>TikTok Ads</span><i></i><span>Policy</span><i></i><span>Appeals</span><i></i><span>Account Operations</span><i></i>
      <span>Meta Ads</span><i></i><span>Google Ads</span><i></i><span>TikTok Ads</span><i></i><span>Policy</span><i></i><span>Appeals</span><i></i><span>Account Operations</span><i></i>
    </div>
  </div>

  <section class="platform-desk" id="platforms">
    <div class="container">
      <header class="home-section-head">
        <div>
          <p class="home-kicker home-kicker--dark"><span></span> Choose your entry point</p>
          <h2>Every platform speaks a<br />different <em>language.</em></h2>
        </div>
        <div class="section-sidecopy">
          <span>01—03</span>
          <p>Start with the platform that issued the decision. We’ll help you identify the surface, preserve the evidence and follow the right review path.</p>
        </div>
      </header>

      <div class="platform-showcase">
        {platformSections.map((section, index) => (
          <a class="platform-panel" data-platform={section.accent} href={`/${section.slug}/`}>
            <div class="platform-panel__top">
              <span class="platform-glyph" aria-hidden="true">{platformCodes[section.accent]}</span>
              <span class="platform-index">0{index + 1} / 03</span>
            </div>
            <div class="platform-panel__body">
              <p>{section.eyebrow}</p>
              <h3>{section.title}</h3>
              <ul aria-label="Coverage areas">
                {platformSignals[section.accent].map((signal) => <li>{signal}</li>)}
              </ul>
            </div>
            <div class="platform-panel__foot">
              <span>{section.topics.length} field guides</span>
              <b aria-hidden="true">↗</b>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="response-system">
    <div class="container response-system__grid">
      <div class="response-intro">
        <p class="home-kicker"><span></span> The AGrowth response system</p>
        <h2>Clarity is a<br /><em>competitive edge.</em></h2>
        <p>A restriction is an operating problem before it is an appeal problem. Build the full picture, correct what can be verified, then respond with consistency.</p>
        <a href="/appeals-compliance/">Explore appeals & compliance <span aria-hidden="true">↗</span></a>
      </div>

      <div class="response-steps">
        <article>
          <div class="step-orbit"><span>01</span><i></i></div>
          <div><p>Observe</p><h3>Map the restriction</h3><span>Identify the affected ad, account, payment profile, business entity or connected asset.</span></div>
        </article>
        <article>
          <div class="step-orbit"><span>02</span><i></i></div>
          <div><p>Resolve</p><h3>Correct the cause</h3><span>Review policy, security, identity and billing signals before making account changes.</span></div>
        </article>
        <article>
          <div class="step-orbit"><span>03</span><i></i></div>
          <div><p>Respond</p><h3>Prepare the review</h3><span>Submit a clear record of the issue, remediation, evidence and preventive controls.</span></div>
        </article>
      </div>
    </div>
  </section>

  <section class="knowledge-section" id="knowledge">
    <div class="container">
      <header class="home-section-head home-section-head--compact">
        <div>
          <p class="home-kicker home-kicker--dark"><span></span> Beyond a single incident</p>
          <h2>Build operations that<br /><em>hold up under pressure.</em></h2>
        </div>
        <a class="view-all" href="/blog/">View all guides <span aria-hidden="true">↗</span></a>
      </header>

      <div class="knowledge-grid">
        {guideSections.map((section, index) => (
          <a class="knowledge-card" href={`/${section.slug}/`}>
            <span class="knowledge-card__index">0{index + 1}</span>
            <div class="knowledge-card__icon" aria-hidden="true">
              {index === 0 && <svg viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="15"/><path d="m13 20 5 5 10-11"/></svg>}
              {index === 1 && <svg viewBox="0 0 40 40" fill="none"><rect x="9" y="12" width="22" height="19" rx="2"/><path d="M15 12V8h10v4M15 19h10M15 25h7"/></svg>}
              {index === 2 && <svg viewBox="0 0 40 40" fill="none"><path d="M20 7v26M7 20h26"/><circle cx="20" cy="20" r="9"/></svg>}
            </div>
            <div>
              <p>{section.eyebrow}</p>
              <h3>{section.title}</h3>
              <span>{section.description}</span>
            </div>
            <b aria-hidden="true">↗</b>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container home-cta__inner">
      <div class="cta-seal" aria-hidden="true"><span>AG</span><i></i><b>GROWTH WITHOUT GUESSWORK</b></div>
      <div class="home-cta__copy">
        <p class="home-kicker"><span></span> Let’s move forward</p>
        <h2>Turn account friction<br />into a <em>clear next move.</em></h2>
      </div>
      <div class="home-cta__action">
        <p>Connect with AGrowth about advertising account operations and agency account solutions.</p>
        <a class="home-button home-button--light" href="/contact/"><span>Start a conversation</span><b aria-hidden="true">↗</b></a>
      </div>
    </div>
  </section>

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const progress = document.querySelector<HTMLElement>('.scroll-progress');
    const header = document.querySelector<HTMLElement>('.site-header');
    let ticking = false;

    const updateScrollEffects = () => {
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = maxScroll > 0 ? Math.min(window.scrollY / maxScroll, 1) : 0;
      progress?.style.setProperty('transform', `scaleX(${ratio})`);
      header?.classList.toggle('is-scrolled', window.scrollY > 30);

      if (!reduceMotion) {
        document.documentElement.style.setProperty('--hero-parallax', `${Math.min(window.scrollY * .07, 110)}px`);
        const response = document.querySelector<HTMLElement>('.response-system');
        if (response) {
          const rect = response.getBoundingClientRect();
          const offset = Math.max(-90, Math.min(90, (rect.top - window.innerHeight) * -.035));
          document.documentElement.style.setProperty('--response-parallax', `${offset}px`);
        }
      }
      ticking = false;
    };

    const requestScrollUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateScrollEffects);
        ticking = true;
      }
    };

    window.addEventListener('scroll', requestScrollUpdate, { passive: true });
    window.addEventListener('resize', requestScrollUpdate, { passive: true });
    updateScrollEffects();

    if (!reduceMotion && 'IntersectionObserver' in window) {
      const groups = [
        '.platform-desk .home-section-head',
        '.platform-panel',
        '.response-intro',
        '.response-steps article',
        '.knowledge-section .home-section-head',
        '.knowledge-card',
        '.home-cta__inner'
      ];
      const elements = groups.flatMap((selector) => Array.from(document.querySelectorAll<HTMLElement>(selector)));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: .12, rootMargin: '0px 0px -7% 0px' });

      elements.forEach((element) => {
        const siblings = element.parentElement
          ? Array.from(element.parentElement.children).filter((child) => child.matches(element.tagName.toLowerCase()))
          : [];
        const index = Math.max(0, siblings.indexOf(element));
        element.style.setProperty('--reveal-delay', `${Math.min(index * 110, 330)}ms`);
        element.classList.add('reveal-ready');
        observer.observe(element);
      });
    }
  </script>
</BaseLayout>
