---
import BaseLayout from '../layouts/BaseLayout.astro';
import { platformSections, guideSections } from '../data/site';
import { companyMetrics, companyProfileUrl } from '../data/authority';
import '../styles/home.css';

const description = 'Policy-led guidance for Meta, Google Ads and TikTok Ads account restrictions, suspensions, reviews and appeals, with operational controls to prevent repeat issues.';
const platformCodes: Record<string, string> = { meta: 'M', google: 'G', tiktok: 'T' };
const platformSignals: Record<string, string[]> = {
  meta: ['Restrictions', 'Business assets', 'Account review'],
  google: ['Suspensions', 'Verification', 'Reinstatement'],
  tiktok: ['Account health', 'Business Center', 'Appeals']
};
const homepagePlatformTitles: Record<string, string> = {
  'meta-ads': 'Diagnose Meta Ads restrictions and account reviews',
  'google-ads': 'Diagnose Google Ads suspensions and reinstatement paths',
  'tiktok-ads': 'Diagnose TikTok Ads and Business Center restrictions'
};
const homepageGuideCopy: Record<string, { title: string; description: string }> = {
  'appeals-compliance': {
    title: 'Prepare appeals that explain the issue, correction and evidence',
    description: 'Turn policy findings, remediation and supporting records into a clear, consistent review submission.'
  },
  'agency-ad-accounts': {
    title: 'Set clear ownership and controls for agency ad accounts',
    description: 'Evaluate providers, permissions, billing, verification, incident response and account portability before client spend is at risk.'
  },
  'account-operations': {
    title: 'Prevent avoidable restrictions with reliable account operations',
    description: 'Standardize security, billing, access, verification and monitoring across every advertising account.'
  }
};
const homepageControlModules = [
  { label: 'Evidence control', code: 'REVIEW / RECORD' },
  { label: 'Ownership control', code: 'ACCESS / BILLING' },
  { label: 'Operations control', code: 'MONITOR / PREVENT' }
];
---

<BaseLayout title="Ad Account Restrictions & Appeals | AGrowth" description={description} bodyClass="home-page">
  <div class="scroll-progress" aria-hidden="true"></div>
  <section class="story-hero" data-story>
    <div class="story-stage">
      <div class="hero-noise" aria-hidden="true"></div>
      <div class="story-aurora" aria-hidden="true"></div>

      <div class="story-copy">
        <p class="home-kicker"><span></span> Account restrictions, appeals &amp; compliance — Meta, Google, TikTok Ads</p>
        <h1>Restricted, suspended,<br />or under review.<br /><em>Know your next move.</em></h1>
        <p>Practical, policy-led guidance to diagnose the issue, fix the root cause, and prepare a review that holds up — plus the operational groundwork to avoid repeat issues.</p>
        <ul class="story-signals" aria-label="Guidance focus">
          <li>Policy-led diagnosis</li>
          <li>Evidence-based appeals</li>
          <li>Preventive operations</li>
        </ul>
      </div>

      <div class="story-world" aria-hidden="true">
        <svg class="story-orbits" viewBox="0 0 1000 620" fill="none">
          <ellipse cx="500" cy="310" rx="355" ry="178" />
          <ellipse cx="500" cy="310" rx="245" ry="286" transform="rotate(32 500 310)" />
          <path class="story-drawn-path" d="M76 405C174 112 405 57 578 174C751 290 765 505 938 533" />
        </svg>

        <div class="story-core">
          <span class="story-core__ring story-core__ring--one"></span>
          <span class="story-core__ring story-core__ring--two"></span>
          <img src="/brand/agrowth-mark-640.webp" alt="" width="640" height="640" fetchpriority="high" />
          <small>AG / SIGNAL 01</small>
        </div>

        <div class="story-float-card story-float-card--meta" data-story-card data-x="-390" data-y="-168" data-r="-7">
          <span><i></i> Meta Ads</span><strong>Restriction mapped</strong><small>Affected asset identified</small>
        </div>
        <div class="story-float-card story-float-card--google" data-story-card data-x="370" data-y="-154" data-r="6">
          <span><i></i> Google Ads</span><strong>Evidence preserved</strong><small>Account history organized</small>
        </div>
        <div class="story-float-card story-float-card--tiktok" data-story-card data-x="-345" data-y="178" data-r="5">
          <span><i></i> TikTok Ads</span><strong>Root cause reviewed</strong><small>Policy · Billing · Security</small>
        </div>
        <div class="story-float-card story-float-card--review" data-story-card data-x="365" data-y="188" data-r="-5">
          <span><i></i> Review path</span><strong>Review package ready</strong><small>Clear. Consistent. Verifiable.</small>
        </div>

        <svg class="story-sketch" viewBox="0 0 180 120" fill="none">
          <path d="M8 103C39 96 74 77 91 48C100 33 104 18 109 7M109 7C114 25 126 39 145 46M109 7C94 13 79 15 66 13" />
        </svg>
      </div>

      <div class="story-resolution">
        <p>A disciplined response process</p>
        <h2>Diagnose. Resolve. <em>Respond.</em></h2>
        <div class="story-actions">
          <a class="home-button home-button--primary" href="#platforms"><span>Choose your platform</span><b aria-hidden="true">↗</b></a>
          <a class="home-button home-button--text" href="/contact/"><span>Talk to AGrowth</span><b aria-hidden="true">→</b></a>
        </div>
      </div>

      <div class="story-scroll-cue" aria-hidden="true"><span>Scroll to explore</span><i></i></div>
    </div>
  </section>

  <section class="story-proof" aria-label="AGrowth company figures">
    <div class="container hero-metrics">
      {companyMetrics.map((metric) => (
        <div class="hero-metric"><strong>{metric.value}</strong><span>{metric.label}</span></div>
      ))}
      <a href={companyProfileUrl} rel="external">Company-reported figures <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <div class="signal-ticker" aria-hidden="true">
    <div class="signal-ticker__track">
      <span>Meta Ads</span><i></i><span>Google Ads</span><i></i><span>TikTok Ads</span><i></i><span>Restrictions</span><i></i><span>Suspensions</span><i></i><span>Appeals</span><i></i><span>Preventive Operations</span><i></i>
      <span>Meta Ads</span><i></i><span>Google Ads</span><i></i><span>TikTok Ads</span><i></i><span>Restrictions</span><i></i><span>Suspensions</span><i></i><span>Appeals</span><i></i><span>Preventive Operations</span><i></i>
    </div>
  </div>

  <section class="platform-desk" id="platforms" data-platform-story>
    <div class="platform-desk__sticky">
    <div class="container">
      <header class="home-section-head">
        <div>
          <p class="home-kicker home-kicker--dark"><span></span> Meta, Google &amp; TikTok decision paths</p>
          <h2>Identify the decision.<br />Follow the right <em>review path.</em></h2>
        </div>
        <div class="section-sidecopy">
          <span>01—03</span>
          <p>Start with the platform that restricted, suspended or placed the account under review. Identify the affected asset, preserve the evidence and follow that platform’s review path.</p>
        </div>
      </header>

      <div class="platform-progress" aria-hidden="true">
        <div class="platform-progress__labels">
          {platformSections.map((section, index) => (
            <span data-platform-label><b>0{index + 1}</b>{section.accent} Ads</span>
          ))}
        </div>
        <div class="platform-progress__rail"><i data-platform-meter></i></div>
        <small>Compare review paths</small>
      </div>

      <div class="platform-viewport">
      <div class="platform-showcase" data-platform-track>
        {platformSections.map((section, index) => (
          <a class="platform-panel" data-platform={section.accent} data-platform-card href={`/${section.slug}/`}>
            <div class="platform-panel__top">
              <span class="platform-glyph" aria-hidden="true">{platformCodes[section.accent]}</span>
              <span class="platform-index">0{index + 1} / 03</span>
            </div>
            <div class="platform-panel__body">
              <p>{section.eyebrow}</p>
              <h3>{homepagePlatformTitles[section.slug] ?? section.title}</h3>
              <ul aria-label="Coverage areas">
                {platformSignals[section.accent].map((signal) => <li>{signal}</li>)}
              </ul>
            </div>
            <div class="platform-panel__foot">
              <span>{section.topics.length} field guides</span>
              <b aria-hidden="true">↗</b>
            </div>
          </a>
        ))}
      </div>
      </div>
    </div>
    </div>
  </section>

  <section class="response-system" data-response-system>
    <div class="container response-system__grid">
      <div class="response-intro">
        <p class="home-kicker"><span></span> The AGrowth response process</p>
        <h2>Handle the restriction<br /><em>in the right order.</em></h2>
        <p>Treat a restriction as an operating problem before an appeal task. Establish what changed and where, correct only verified causes, then submit a consistent evidence record.</p>
        <a href="/appeals-compliance/">Explore appeals & compliance <span aria-hidden="true">↗</span></a>
      </div>

      <div class="response-steps">
        <article data-response-step>
          <div class="step-orbit"><span>01</span><i></i></div>
          <div><p>Observe</p><h3>Map the restriction</h3><span>Identify the affected ad, account, payment profile, business entity or connected asset.</span></div>
        </article>
        <article data-response-step>
          <div class="step-orbit"><span>02</span><i></i></div>
          <div><p>Resolve</p><h3>Correct the root cause</h3><span>Check policy, security, identity, billing and destination signals before changing the account.</span></div>
        </article>
        <article data-response-step>
          <div class="step-orbit"><span>03</span><i></i></div>
          <div><p>Respond</p><h3>Prepare the review</h3><span>Present the issue, corrective action, supporting evidence and controls to prevent recurrence.</span></div>
        </article>
      </div>
    </div>
  </section>

  <section class="knowledge-section" id="knowledge">
    <div class="container">
      <header class="home-section-head home-section-head--compact">
        <div>
          <p class="home-kicker home-kicker--dark"><span></span> Prevent repeat issues</p>
          <h2>Build controls that reduce<br /><em>repeat restrictions.</em></h2>
        </div>
        <a class="view-all" href="/blog/">View all guides <span aria-hidden="true">↗</span></a>
      </header>

      <div class="knowledge-grid">
        {guideSections.map((section, index) => (
          <a class="knowledge-card" data-depth-card href={`/${section.slug}/`}>
            <span class="knowledge-card__index">0{index + 1}</span>
            <div class="knowledge-card__body">
              <p>{section.eyebrow}</p>
              <h3>{homepageGuideCopy[section.slug]?.title ?? section.title}</h3>
              <span>{homepageGuideCopy[section.slug]?.description ?? section.description}</span>
            </div>
            <div class="knowledge-card__visual" aria-hidden="true">
              <span class="knowledge-card__status"><i></i>{homepageControlModules[index].label}</span>
              <div class="knowledge-card__icon">
                {index === 0 && <svg viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="15"/><path d="m13 20 5 5 10-11"/></svg>}
                {index === 1 && <svg viewBox="0 0 40 40" fill="none"><rect x="9" y="12" width="22" height="19" rx="2"/><path d="M15 12V8h10v4M15 19h10M15 25h7"/></svg>}
                {index === 2 && <svg viewBox="0 0 40 40" fill="none"><path d="M20 7v26M7 20h26"/><circle cx="20" cy="20" r="9"/></svg>}
              </div>
              <small>{homepageControlModules[index].code}<b>{String(section.topics.length).padStart(2, '0')} guides</b></small>
            </div>
            <b aria-hidden="true">↗</b>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container home-cta__inner">
      <div class="cta-seal" aria-hidden="true"><span>AG</span><i></i><b>GROWTH WITHOUT GUESSWORK</b></div>
      <div class="home-cta__copy">
        <p class="home-kicker"><span></span> Before you change the account</p>
        <h2>Make the next move<br /><em>with a clear record.</em></h2>
      </div>
      <div class="home-cta__action">
        <p>Talk to AGrowth about a current restriction, an upcoming review or the controls needed to prevent repeat issues.</p>
        <a class="home-button home-button--light" href="/contact/"><span>Discuss your account</span><b aria-hidden="true">↗</b></a>
      </div>
    </div>
  </section>

  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const progress = document.querySelector<HTMLElement>('.scroll-progress');
    const header = document.querySelector<HTMLElement>('.site-header');
    const story = document.querySelector<HTMLElement>('[data-story]');
    const storyStage = story?.querySelector<HTMLElement>('.story-stage');
    const storyCards = Array.from(story?.querySelectorAll<HTMLElement>('[data-story-card]') ?? []);
    const platformStory = document.querySelector<HTMLElement>('[data-platform-story]');
    const platformSticky = platformStory?.querySelector<HTMLElement>('.platform-desk__sticky');
    const platformViewport = platformStory?.querySelector<HTMLElement>('.platform-viewport');
    const platformTrack = platformStory?.querySelector<HTMLElement>('[data-platform-track]');
    const platformCards = Array.from(platformStory?.querySelectorAll<HTMLElement>('[data-platform-card]') ?? []);
    const platformLabels = Array.from(platformStory?.querySelectorAll<HTMLElement>('[data-platform-label]') ?? []);
    const platformMeter = platformStory?.querySelector<HTMLElement>('[data-platform-meter]');
    const responseSystem = document.querySelector<HTMLElement>('[data-response-system]');
    const responseSteps = Array.from(responseSystem?.querySelectorAll<HTMLElement>('[data-response-step]') ?? []);
    let ticking = false;

    const clamp = (value: number, min = 0, max = 1) => Math.min(Math.max(value, min), max);
    const range = (value: number, start: number, end: number) => clamp((value - start) / (end - start));
    const ease = (value: number) => value * value * (3 - 2 * value);

    const updateScrollEffects = () => {
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = maxScroll > 0 ? Math.min(window.scrollY / maxScroll, 1) : 0;
      progress?.style.setProperty('transform', `scaleX(${ratio})`);
      header?.classList.toggle('is-scrolled', window.scrollY > 30);

      if (!reduceMotion) {
        if (story && storyStage) {
          const rect = story.getBoundingClientRect();
          const distance = Math.max(1, story.offsetHeight - storyStage.offsetHeight);
          const storyProgress = clamp(-rect.top / distance);
          const titleOut = ease(range(storyProgress, .06, .3));
          const worldIn = ease(range(storyProgress, .08, .4));
          const spread = ease(range(storyProgress, .18, .58));
          const cardOpacity = ease(range(storyProgress, .13, .31));
          const resolutionIn = ease(range(storyProgress, .66, .86));
          const sketchIn = ease(range(storyProgress, .38, .67));

          storyStage.style.setProperty('--story-progress', String(storyProgress));
          storyStage.style.setProperty('--story-title-opacity', String(1 - titleOut));
          storyStage.style.setProperty('--story-title-y', `${storyProgress * -110}px`);
          storyStage.style.setProperty('--story-title-scale', String(1 - storyProgress * .035));
          storyStage.style.setProperty('--story-world-opacity', String(.12 + worldIn * .88));
          storyStage.style.setProperty('--story-world-scale', String((.62 + worldIn * .38) * (1 - resolutionIn * .14)));
          storyStage.style.setProperty('--story-world-rotate', `${-4 + storyProgress * 7}deg`);
          storyStage.style.setProperty('--story-world-y', `${resolutionIn * -125}px`);
          storyStage.style.setProperty('--story-core-scale', String(.86 + worldIn * .18));
          storyStage.style.setProperty('--story-aurora-scale', String(.72 + worldIn * .4));
          storyStage.style.setProperty('--story-resolution-opacity', String(resolutionIn));
          storyStage.style.setProperty('--story-resolution-y', `${(1 - resolutionIn) * 45}px`);
          storyStage.style.setProperty('--story-cue-opacity', String(1 - ease(range(storyProgress, .01, .16))));
          storyStage.style.setProperty('--story-path-offset', String(1350 * (1 - spread)));
          storyStage.style.setProperty('--story-sketch-opacity', String(sketchIn));
          storyStage.style.setProperty('--story-sketch-offset', String(410 * (1 - sketchIn)));
          storyStage.style.setProperty('--story-resolution-events', resolutionIn > .8 ? 'auto' : 'none');

          const mobile = window.innerWidth < 700;
          storyCards.forEach((card) => {
            let x = Number(card.dataset.x ?? 0);
            let y = Number(card.dataset.y ?? 0);
            const rotation = Number(card.dataset.r ?? 0);
            if (mobile) {
              const isLeft = card.classList.contains('story-float-card--meta');
              const isRight = card.classList.contains('story-float-card--review');
              if (isLeft) { x = -112; y = -132; }
              if (isRight) { x = 108; y = -126; }
            } else if (window.innerWidth < 1100) {
              x *= .7;
              y *= .72;
            }
            const lowerCard = card.classList.contains('story-float-card--tiktok') || card.classList.contains('story-float-card--review');
            const sceneFade = lowerCard ? 1 - resolutionIn * .92 : 1 - resolutionIn * .58;
            card.style.opacity = String(cardOpacity * sceneFade);
            card.style.transform = `translate3d(${x * spread}px, ${y * spread}px, 0) rotate(${rotation * spread}deg) scale(${.82 + spread * .18})`;
          });
        }

        if (platformStory && platformSticky && platformViewport && platformTrack) {
          const desktopStory = window.innerWidth > 980;
          if (desktopStory) {
            const rect = platformStory.getBoundingClientRect();
            const distance = Math.max(1, platformStory.offsetHeight - platformSticky.offsetHeight);
            const platformProgress = clamp(-rect.top / distance);
            const maxShift = Math.max(0, platformTrack.scrollWidth - platformViewport.clientWidth);
            platformTrack.style.transform = `translate3d(${-maxShift * ease(platformProgress)}px, 0, 0)`;
            platformMeter?.style.setProperty('transform', `scaleX(${platformProgress})`);

            const activeIndex = Math.min(
              platformCards.length - 1,
              Math.max(0, Math.round(platformProgress * (platformCards.length - 1)))
            );
            platformCards.forEach((card, index) => card.classList.toggle('is-active', index === activeIndex));
            platformLabels.forEach((label, index) => label.classList.toggle('is-active', index === activeIndex));
          } else {
            platformTrack.style.transform = '';
            platformMeter?.style.setProperty('transform', 'scaleX(1)');
            platformCards.forEach((card) => card.classList.remove('is-active'));
            platformLabels.forEach((label) => label.classList.remove('is-active'));
          }
        }

        if (responseSystem) {
          const rect = responseSystem.getBoundingClientRect();
          const offset = Math.max(-90, Math.min(90, (rect.top - window.innerHeight) * -.035));
          document.documentElement.style.setProperty('--response-parallax', `${offset}px`);

          let activeStep = 0;
          let nearestDistance = Number.POSITIVE_INFINITY;
          responseSteps.forEach((step, index) => {
            const stepRect = step.getBoundingClientRect();
            const focusLine = window.innerWidth > 980 ? .46 : .5;
            const distance = Math.abs(stepRect.top + stepRect.height * .5 - window.innerHeight * focusLine);
            if (distance < nearestDistance) {
              nearestDistance = distance;
              activeStep = index;
            }
          });
          responseSteps.forEach((step, index) => {
            step.classList.toggle('is-active', index === activeStep);
            step.classList.toggle('is-past', index < activeStep);
          });
          const stepProgress = responseSteps.length > 1 ? activeStep / (responseSteps.length - 1) : 1;
          responseSystem.style.setProperty('--response-step-progress', String(stepProgress));
        }
      }
      ticking = false;
    };

    const requestScrollUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateScrollEffects);
        ticking = true;
      }
    };

    window.addEventListener('scroll', requestScrollUpdate, { passive: true });
    window.addEventListener('resize', requestScrollUpdate, { passive: true });
    updateScrollEffects();

    if (!reduceMotion && window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll<HTMLElement>('[data-depth-card]').forEach((card) => {
        card.addEventListener('pointermove', (event) => {
          const rect = card.getBoundingClientRect();
          const x = clamp((event.clientX - rect.left) / rect.width);
          const y = clamp((event.clientY - rect.top) / rect.height);
          card.style.setProperty('--spot-x', `${x * 100}%`);
          card.style.setProperty('--spot-y', `${y * 100}%`);
          card.style.setProperty('--card-shift-x', `${(x - .5) * 12}px`);
          card.style.setProperty('--card-shift-y', `${(y - .5) * 12}px`);
        });
        card.addEventListener('pointerleave', () => {
          card.style.removeProperty('--card-shift-x');
          card.style.removeProperty('--card-shift-y');
        });
      });
    }

    if (!reduceMotion && 'IntersectionObserver' in window) {
      const groups = [
        '.platform-desk .home-section-head',
        '.response-intro',
        '.response-steps article',
        '.knowledge-section .home-section-head',
        '.knowledge-card',
        '.home-cta__inner'
      ];
      const elements = groups.flatMap((selector) => Array.from(document.querySelectorAll<HTMLElement>(selector)));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: .12, rootMargin: '0px 0px -7% 0px' });

      elements.forEach((element) => {
        const siblings = element.parentElement
          ? Array.from(element.parentElement.children).filter((child) => child.matches(element.tagName.toLowerCase()))
          : [];
        const index = Math.max(0, siblings.indexOf(element));
        element.style.setProperty('--reveal-delay', `${Math.min(index * 110, 330)}ms`);
        element.classList.add('reveal-ready');
        observer.observe(element);
      });
    }
  </script>
</BaseLayout>
