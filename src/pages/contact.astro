---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact AGrowth" description="Contact AGrowth about Meta, Google Ads and TikTok Ads account operations, compliance and agency account solutions.">
  <section class="page-hero">
    <div class="container page-hero-inner">
      <p class="eyebrow">Contact AGrowth</p>
      <h1>Start with the account context.</h1>
      <p class="lede">When you get in touch, include the platform, restriction surface, date of the notice, and the steps already taken. Do not send passwords, full payment details, or recovery codes.</p>
      <div class="contact-grid">
        <article class="contact-card">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="m5 7 7 6 7-6" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
          <h2>Find AGrowth</h2>
          <p>Visit the official GitHub profile connected to this website and its published projects.</p>
          <a href="https://github.com/agrowthagency" rel="me">AGrowth on GitHub →</a>
        </article>
        <article class="contact-card">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-5 4v-4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.8"/><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          <h2>Prepare your brief</h2>
          <p>Platform, account type, visible notice, timeline, recent changes, and available documentation.</p>
          <a href="/appeals-compliance/">Review appeal guidance →</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
