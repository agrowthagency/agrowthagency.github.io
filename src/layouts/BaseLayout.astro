---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/brand.css';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  image?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  bodyClass?: string;
}

const {
  title,
  seoTitle,
  description,
  image = '/brand/agrowth-logo-original.jpg',
  noindex = false,
  structuredData,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  bodyClass
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = seoTitle ?? (title.includes('Ad Account Desk') ? title : `${title} | Ad Account Desk by AGrowth`);
const socialImage = new URL(image, Astro.site);
const resolvedBodyClass = [bodyClass, bodyClass === 'home-page' ? '' : 'inner-page'].filter(Boolean).join(' ');
const siteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).href,
      name: 'Ad Account Desk by AGrowth',
      url: Astro.site,
      description,
      publisher: { '@id': new URL('/#organization', Astro.site).href }
    },
    {
      '@type': 'Organization',
      '@id': new URL('/#organization', Astro.site).href,
      name: 'AGrowth',
      url: 'https://agrowth.io/',
      logo: new URL('/brand/agrowth-mark-640.webp', Astro.site).href
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="48x48" href="/brand/favicon-48.png" />
    <meta name="theme-color" content="#fff2e6" />
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body class={resolvedBodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {bodyClass !== 'home-page' && <div class="inner-scroll-progress" aria-hidden="true"></div>}
    <Header />
    <main id="main-content" data-pagefind-body={noindex ? undefined : ''}>
      <slot />
    </main>
    <Footer />
    <script>
      const page = document.body;
      const motionPreference = window.matchMedia('(prefers-reduced-motion: reduce)');
      const finePointer = window.matchMedia('(pointer: fine)');

      /*
       * Add a restrained inertial layer to desktop wheel input. Touch, keyboard,
       * nested scroll areas and reduced-motion users retain native scrolling.
       */
      if (!motionPreference.matches && finePointer.matches) {
        const root = document.documentElement;
        const isHomepage = page.classList.contains('home-page');
        const responseTime = isHomepage ? 140 : 105;
        const wheelGain = isHomepage ? .88 : .96;
        const lineSize = Number.parseFloat(window.getComputedStyle(root).fontSize) * 1.5;
        let currentPosition = window.scrollY;
        let targetPosition = window.scrollY;
        let animationFrame = 0;
        let previousTime = 0;

        const getMaxScroll = () => Math.max(0, root.scrollHeight - window.innerHeight);
        const clampScroll = (value: number) => Math.min(Math.max(value, 0), getMaxScroll());

        const hasNestedScrollRoom = (origin: EventTarget | null, delta: number) => {
          let element = origin instanceof Element ? origin : null;
          while (element && element !== page && element !== root) {
            if (element.scrollHeight > element.clientHeight + 1) {
              const scrollable = /(auto|scroll|overlay)/.test(window.getComputedStyle(element).overflowY);
              const canMoveUp = delta < 0 && element.scrollTop > 0;
              const canMoveDown = delta > 0 && element.scrollTop + element.clientHeight < element.scrollHeight - 1;
              if (scrollable && (canMoveUp || canMoveDown)) return true;
            }
            element = element.parentElement;
          }
          return false;
        };

        const stopInertia = () => {
          if (animationFrame) window.cancelAnimationFrame(animationFrame);
          animationFrame = 0;
          previousTime = 0;
          currentPosition = window.scrollY;
          targetPosition = window.scrollY;
          root.classList.remove('is-inertia-scrolling');
        };

        const renderInertia = (time: number) => {
          const elapsed = previousTime ? Math.min(time - previousTime, 34) : 16.67;
          previousTime = time;
          targetPosition = clampScroll(targetPosition);
          const blend = 1 - Math.exp(-elapsed / responseTime);
          currentPosition += (targetPosition - currentPosition) * blend;

          if (Math.abs(targetPosition - currentPosition) < .45) {
            currentPosition = targetPosition;
            window.scrollTo(0, currentPosition);
            stopInertia();
            return;
          }

          window.scrollTo(0, currentPosition);
          animationFrame = window.requestAnimationFrame(renderInertia);
        };

        const onWheel = (event: WheelEvent) => {
          if (
            motionPreference.matches ||
            !finePointer.matches ||
            window.innerWidth <= 768 ||
            event.defaultPrevented ||
            event.ctrlKey ||
            event.metaKey ||
            event.shiftKey ||
            event.deltaY === 0 ||
            Math.abs(event.deltaX) > Math.abs(event.deltaY) ||
            hasNestedScrollRoom(event.target, event.deltaY)
          ) return;

          const interactiveTarget = event.target instanceof Element
            ? event.target.closest('select, textarea, [contenteditable="true"]')
            : null;
          if (interactiveTarget) return;

          event.preventDefault();

          if (!animationFrame) {
            currentPosition = window.scrollY;
            targetPosition = window.scrollY;
          }

          const modeScale = event.deltaMode === WheelEvent.DOM_DELTA_LINE
            ? lineSize
            : event.deltaMode === WheelEvent.DOM_DELTA_PAGE
              ? window.innerHeight
              : 1;
          const normalizedDelta = Math.min(Math.max(event.deltaY * modeScale, -260), 260);
          targetPosition = clampScroll(targetPosition + normalizedDelta * wheelGain);
          root.classList.add('is-inertia-scrolling');

          if (!animationFrame) animationFrame = window.requestAnimationFrame(renderInertia);
        };

        window.addEventListener('wheel', onWheel, { passive: false });
        window.addEventListener('resize', () => {
          targetPosition = clampScroll(targetPosition);
        }, { passive: true });
        window.addEventListener('scroll', () => {
          if (!animationFrame) {
            currentPosition = window.scrollY;
            targetPosition = window.scrollY;
            return;
          }

          if (Math.abs(window.scrollY - currentPosition) > 3) stopInertia();
        }, { passive: true });
        window.addEventListener('keydown', stopInertia, { capture: true });
        window.addEventListener('pointerdown', stopInertia, { capture: true });
        window.addEventListener('blur', stopInertia);
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) stopInertia();
        });
      }

      if (page.classList.contains('inner-page')) {
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const progress = document.querySelector<HTMLElement>('.inner-scroll-progress');
        const header = document.querySelector<HTMLElement>('.site-header');
        const articleHero = document.querySelector<HTMLElement>('.article-hero');
        const pageHero = document.querySelector<HTMLElement>('.page-hero, .search-shell');
        const articleLayout = document.querySelector<HTMLElement>('.article-layout');
        const articleSidebar = document.querySelector<HTMLElement>('.article-sidebar');
        const articleContent = document.querySelector<HTMLElement>('.article-content');
        const tocNav = articleSidebar?.querySelector<HTMLElement>('nav');
        const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.article-sidebar nav a[href^="#"]'));
        const tocTargets = tocLinks
          .map((link) => document.querySelector<HTMLElement>(link.hash))
          .filter((target): target is HTMLElement => Boolean(target));
        let ticking = false;
        let activeTocIndex = -1;

        const updatePageMotion = () => {
          const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
          const scrollRatio = maxScroll > 0 ? Math.min(window.scrollY / maxScroll, 1) : 0;
          progress?.style.setProperty('transform', `scaleX(${scrollRatio})`);
          header?.classList.toggle('is-scrolled', window.scrollY > 24);

          if (!reduceMotion) {
            const hero = articleHero ?? pageHero;
            if (hero) {
              const heroOffset = Math.max(-90, Math.min(90, window.scrollY * .065));
              hero.style.setProperty('--inner-hero-shift', `${heroOffset}px`);
            }
          }

          if (tocLinks.length && tocTargets.length) {
            let activeIndex = 0;
            const trigger = window.innerHeight * .34;
            tocTargets.forEach((target, index) => {
              if (target.getBoundingClientRect().top <= trigger) activeIndex = index;
            });
            tocLinks.forEach((link, index) => {
              if (index === activeIndex) link.setAttribute('aria-current', 'location');
              else link.removeAttribute('aria-current');
            });

            if (articleContent && articleSidebar && articleLayout) {
              const contentRect = articleContent.getBoundingClientRect();
              const contentStart = window.scrollY + contentRect.top;
              const contentEnd = contentStart + articleContent.offsetHeight;
              const readingPoint = window.scrollY + trigger;
              const tocProgress = Math.min(Math.max((readingPoint - contentStart) / Math.max(1, contentEnd - contentStart), 0), 1);
              articleSidebar.style.setProperty('--toc-progress', String(tocProgress));

              const layoutRect = articleLayout.getBoundingClientRect();
              const stickyTop = 110;
              const isSticky = window.innerWidth > 980 && layoutRect.top <= stickyTop && layoutRect.bottom > stickyTop + articleSidebar.offsetHeight;
              articleSidebar.classList.toggle('is-toc-stuck', isSticky);
            }

            if (activeIndex !== activeTocIndex) {
              activeTocIndex = activeIndex;
              const activeLink = tocLinks[activeIndex];
              if (tocNav && activeLink && window.innerWidth > 980 && tocNav.scrollHeight > tocNav.clientHeight) {
                tocNav.scrollTo({
                  top: activeLink.offsetTop - tocNav.clientHeight * .5 + activeLink.offsetHeight * .5,
                  behavior: reduceMotion ? 'auto' : 'smooth'
                });
              }
            }
          }
          ticking = false;
        };

        const requestPageMotion = () => {
          if (ticking) return;
          window.requestAnimationFrame(updatePageMotion);
          ticking = true;
        };

        window.addEventListener('scroll', requestPageMotion, { passive: true });
        window.addEventListener('resize', requestPageMotion, { passive: true });
        updatePageMotion();

        if (!reduceMotion && 'IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-motion-visible');
              observer.unobserve(entry.target);
            });
          }, { threshold: .09, rootMargin: '0px 0px -6% 0px' });

          const prepare = (element: HTMLElement, index: number, immediate = false) => {
            if (element.classList.contains('motion-item')) return;
            element.classList.add('motion-item');
            element.style.setProperty('--motion-delay', `${Math.min(index * 75, 300)}ms`);
            if (immediate) window.requestAnimationFrame(() => element.classList.add('is-motion-visible'));
            else observer.observe(element);
          };

          const heroItems = Array.from(document.querySelectorAll<HTMLElement>(
            '.page-hero-inner > *, .silo-hero .page-breadcrumbs, .silo-hero__grid > *, .blog-hero__grid > *, .blog-hero .silo-jump, .article-hero .breadcrumbs, .article-hero-copy, .article-meta-card, .search-shell > .container > *'
          ));
          heroItems.forEach((element, index) => prepare(element, index, true));

          const revealSelectors = [
            '.section-heading', '.directory-heading', '.platform-proof', '.info-aside', '.prose',
            '.topic-list-item', '.article-card', '.contact-card', '.trust-metric',
            '.editorial-profile > *', '.desk-faq-layout > *',
            '.related-grid > a', '.footer-grid > *', '.footer-bottom'
          ];
          const revealItems = revealSelectors.flatMap((selector) =>
            Array.from(document.querySelectorAll<HTMLElement>(selector))
          );
          revealItems.forEach((element) => {
            const siblings = element.parentElement ? Array.from(element.parentElement.children) : [];
            prepare(element, Math.max(0, siblings.indexOf(element)));
          });

          const searchResults = document.querySelector<HTMLElement>('#search-results');
          if (searchResults) {
            new MutationObserver(() => {
              Array.from(searchResults.querySelectorAll<HTMLElement>('.search-result'))
                .forEach((element, index) => prepare(element, index));
            }).observe(searchResults, { childList: true });
          }
        }

        if (!reduceMotion && window.matchMedia('(pointer: fine)').matches) {
          document.addEventListener('pointermove', (event) => {
            const card = (event.target as HTMLElement).closest<HTMLElement>(
              '.topic-list-item, .article-card, .contact-card, .related-grid > a, .trust-metric, .search-result'
            );
            if (!card) return;
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--motion-x', `${((event.clientX - rect.left) / rect.width) * 100}%`);
            card.style.setProperty('--motion-y', `${((event.clientY - rect.top) / rect.height) * 100}%`);
          }, { passive: true });
        }
      }
    </script>
  </body>
</html>
