---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/brand.css';

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  image?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  bodyClass?: string;
}

const {
  title,
  seoTitle,
  description,
  image = '/brand/agrowth-logo-original.jpg',
  noindex = false,
  structuredData,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  bodyClass
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const fullTitle = seoTitle ?? (title.includes('Ad Account Desk') ? title : `${title} | Ad Account Desk by AGrowth`);
const socialImage = new URL(image, Astro.site);
const siteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': new URL('/#website', Astro.site).href,
      name: 'Ad Account Desk by AGrowth',
      url: Astro.site,
      description,
      publisher: { '@id': new URL('/#organization', Astro.site).href }
    },
    {
      '@type': 'Organization',
      '@id': new URL('/#organization', Astro.site).href,
      name: 'AGrowth',
      url: 'https://agrowth.io/',
      logo: new URL('/brand/agrowth-mark-640.webp', Astro.site).href
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="48x48" href="/brand/favicon-48.png" />
    <meta name="theme-color" content="#fff2e6" />
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" data-pagefind-body={noindex ? undefined : ''}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
